FROM golang:1.24-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY pkg/ ./pkg/
COPY cmd/batch-processor/ ./cmd/batch-processor/
RUN CGO_ENABLED=0 GOOS=linux go build -a -ldflags="-w -s" -o batch-processor ./cmd/batch-processor/

FROM alpine:latest
RUN apk add --no-cache ca-certificates
COPY --from=builder /build/batch-processor /batch-processor
ENTRYPOINT ["/batch-processor"]
